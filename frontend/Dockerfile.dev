FROM node:20-alpine

WORKDIR /app

# Install dependencies efficiently
COPY package.json package-lock.json* ./
RUN npm install --no-audit 2>&1 | grep -v "npm warn" || true

# Copy configuration files needed for vite to work
COPY tsconfig.json tsconfig.app.json tsconfig.node.json vite.config.ts postcss.config.js tailwind.config.js index.html ./

# Update PATH to ensure node_modules/.bin is available
ENV PATH="/app/node_modules/.bin:$PATH"

# Health check (allowing for startup time)
HEALTHCHECK --interval=30s --timeout=10s --retries=3 --start-period=20s \
  CMD wget --no-verbose --tries=1 --spider http://localhost:5173 || exit 1

EXPOSE 5173

# Start Vite dev server with polling for Docker volumes
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

# Development Dockerfile for Backend with Hot Reload
FROM node:20-alpine

WORKDIR /app

# Copy package files for faster install
COPY package.json package-lock.json* ./

# Install dependencies (use ci if lock file exists, includes tsx for watch mode)
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

# Copy TypeScript configuration
COPY tsconfig.json ./

# Copy source code
COPY src ./src

# Expose backend port
EXPOSE 3000

# Start backend with tsx watch for hot reload
CMD ["npm", "run", "dev"]

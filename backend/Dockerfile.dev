FROM node:20-alpine

WORKDIR /app

# Install dependencies efficiently
COPY package.json package-lock.json* ./
RUN npm install --no-audit 2>&1 | grep -v "npm warn" || true

# Copy TypeScript config for compilation
COPY tsconfig.json ./

# Update PATH to ensure node_modules/.bin is available
ENV PATH="/app/node_modules/.bin:$PATH"

# Health check for development
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3000/health', (r) => {if (r.statusCode !== 200) throw new Error(r.statusCode)}).on('error', () => { process.exit(1) })" || exit 1

EXPOSE 3000

# Start with tsx watch for hot reload with inotify optimization
CMD ["npm", "run", "dev"]

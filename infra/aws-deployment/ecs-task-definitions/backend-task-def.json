{
  "family": "syslab-backend-taskdef",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "syslab-backend",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/syslab-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "BACKEND_PORT",
          "value": "3000"
        },
        {
          "name": "DB_HOST",
          "value": "RDS_ENDPOINT_HERE"
        },
        {
          "name": "DB_PORT",
          "value": "5432"
        },
        {
          "name": "DB_NAME",
          "value": "system_design_simulator"
        },
        {
          "name": "DB_USER",
          "value": "postgres"
        },
        {
          "name": "DB_POOL_MAX",
          "value": "20"
        },
        {
          "name": "REDIS_HOST",
          "value": "ELASTICACHE_ENDPOINT_HERE"
        },
        {
          "name": "REDIS_PORT",
          "value": "6379"
        },
        {
          "name": "FRONTEND_URL",
          "value": "https://syslab.yourdomain.com"
        },
        {
          "name": "JWT_EXPIRY",
          "value": "1h"
        },
        {
          "name": "JWT_REFRESH_EXPIRY",
          "value": "7d"
        },
        {
          "name": "LOG_LEVEL",
          "value": "info"
        },
        {
          "name": "ENABLE_PROMETHEUS_METRICS",
          "value": "true"
        }
      ],
      "secrets": [
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:syslab/db/password"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:syslab/jwt_secret"
        },
        {
          "name": "JWT_REFRESH_SECRET",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:syslab/jwt_refresh_secret"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/syslab-backend",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:3000/health || exit 1"
        ],
        "interval": 15,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },
      "dependsOn": [],
      "ulimits": [],
      "mountPoints": [],
      "volumesFrom": []
    }
  ],
  "volumes": [],
  "status": "ACTIVE",
  "requiresAttributes": [
    {
      "name": "com.amazonaws.ecs.capability.ecr-auth"
    },
    {
      "name": "com.amazonaws.ecs.capability.task-iam-role"
    },
    {
      "name": "com.amazonaws.ecs.capability.task-eni"
    }
  ],
  "placementConstraints": [],
  "compatibilities": ["EC2", "FARGATE"],
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}
